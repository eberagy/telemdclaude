# ============================================================
# TeleMD + AgentOps — Required Environment Variables
# Copy this to .env (root), and app-specific .env files
# NEVER commit actual secrets
# ============================================================

# ---- Database ----
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://telemd:changeme@localhost:5432/telemd
AGENTOPS_DATABASE_URL=postgresql://telemd:changeme@localhost:5432/agentops

# ---- Clerk (Auth) ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Retell AI (Voice Intake) ----
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_WEBHOOK_SECRET=

# ---- Zoom Video SDK ----
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# ---- Anthropic (AI / SOAP Summary + AgentOps) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Email (Postmark) ----
POSTMARK_TOKEN=
POSTMARK_FROM=noreply@yourdomain.com

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ---- Storage (S3-compatible) ----
S3_BUCKET=telemd-files
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- Observability ----
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- Slack (AgentOps) ----
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C...          # #general channel ID
SLACK_ALERTS_CHANNEL_ID=       # Leave empty to use #general

# ---- GitHub (AgentOps) ----
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-github-org
GITHUB_REPO=telemd-monorepo

# ---- AgentOps ----
AGENTOPS_ADMIN_SECRET=         # Auto-generated by create_secrets.sh
AGENTOPS_PUBLIC_URL=http://localhost:4001
TELEMD_API_URL=http://localhost:3001

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# API proxy base for telemd-web → telemd-api rewrites
NEXT_PUBLIC_API_URL=http://localhost:3001
# API proxy base for agentops-ui → agentops-api rewrites
NEXT_PUBLIC_AGENTOPS_API_URL=http://localhost:4000

# ---- Optional / Feature Flags ----
RETELL_WEBHOOK_SECRET=          # Set to match Retell dashboard webhook secret
DEMO_REQUEST_EMAIL=hello@telemd.health   # Where demo requests are emailed
